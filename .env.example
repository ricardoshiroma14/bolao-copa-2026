# Browser/client Supabase config. The publishable key is safe to expose.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Public app URL used for Open Graph metadata.
VITE_APP_URL=http://localhost:5173
VITE_APP_OG_IMAGE_URL=http://localhost:5173/og-image.jpg

# Optional public links/copy. These values are visible in the browser.
VITE_WHATSAPP_GROUP_URL=
VITE_PROTECTED_OWNER_EMAILS=

# Optional public payment copy. These values are visible in the browser.
VITE_PAYMENT_AMOUNT=
VITE_PAYMENT_RECIPIENT=
VITE_PAYMENT_METHOD_LABEL=
VITE_PAYMENT_KEY_LABEL=
VITE_PAYMENT_KEY=
VITE_PAYMENT_BANK=
VITE_PAYMENT_INSTRUCTIONS=

# Server/function-only Supabase config. Never expose the service role key in client code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PROTECTED_OWNER_EMAILS=

# Optional, only required if you deploy/use supabase/functions/sync-matches.
THESPORTSDB_API_KEY=
THESPORTSDB_WORLD_CUP_LEAGUE_ID=4429
THESPORTSDB_WORLD_CUP_SEASON=2026
SYNC_CRON_SECRET=
